{
  "name": "lfs-norisring-ai",
  "version": "0.0.0",
  "main": "dist/index.cjs",
  "bin": "dist/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "run-s build:ts copy-config",
    "build:ts": "tsup src/index.ts",
    "copy-config": "cp config.toml config.local.toml dist/",
    "package": "./scripts/package.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint \"./src/**/*\" --ext .ts",
    "lint:fix": "eslint \"./src/**/*\" --ext .ts --fix",
    "precommit": "run-s format lint:fix build",
    "ci": "run-s format:check lint build"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "debug": "^4.4.3",
    "dotenv": "^17.4.0",
    "lodash.defaults": "^4.2.0",
    "reflect-metadata": "^0.2.2",
    "smol-toml": "^1.6.1",
    "supports-color": "^10.2.2",
    "tiny-typed-emitter": "^2.1.0",
    "zod": "^4.3.6",
    "zod-config": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/debug": "^4.1.13",
    "@types/lodash": "^4.17.24",
    "@types/lodash.defaults": "^4.2.9",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "npm-run-all": "^4.1.5",
    "pkg": "^5.8.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "files": [
    "**/*.js",
    "**/*.d.ts"
  ],
  "pkg": {
    "scripts": "dist/index.js",
    "targets": [
      "node18-win-x64"
    ]
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
